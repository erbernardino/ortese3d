rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function caseRefBy(caseId) {
      return get(/databases/$(database)/documents/cases/$(caseId));
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isCoordinator() {
      return isSignedIn() && userRole() == 'study_coordinator';
    }

    // Perfis: cada usuário só lê e escreve o próprio doc; coordenador lê todos
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isCoordinator());
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role in ['doctor', 'orthotist', 'study_coordinator'];
      allow update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Pacientes: somente o médico criador acessa; coordenador lê para o estudo
    // (ortesistas leem dados denormalizados no doc do caso)
    match /patients/{patientId} {
      allow read:   if isSignedIn() && (
                      resource.data.createdBy == request.auth.uid || isCoordinator()
                    );
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow delete: if false;
    }

    // Casos: leitura/escrita por médico criador OU ortesista atribuído.
    // Coordenador lê todos para análise do estudo.
    match /cases/{caseId} {
      allow read: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.assignedTo == request.auth.uid ||
        isCoordinator()
      );
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.assignedTo == request.auth.uid
      );
      allow delete: if false;

      // Avaliações de evolução — mesmas regras do caso + coordenador lê
      match /evaluations/{evalId} {
        allow read: if isSignedIn() && (
          caseRefBy(caseId).data.createdBy == request.auth.uid ||
          caseRefBy(caseId).data.assignedTo == request.auth.uid ||
          isCoordinator()
        );
        allow create: if isSignedIn() && (
          caseRefBy(caseId).data.createdBy == request.auth.uid ||
          caseRefBy(caseId).data.assignedTo == request.auth.uid
        );
        allow update, delete: if false;
      }
    }

    // Notificações:
    //   - leitura/marcação só pelo destinatário
    //   - criação só por quem é parte do case referenciado
    match /notifications/{id} {
      allow read, update, delete:
        if isSignedIn() && resource.data.toUserId == request.auth.uid;
      allow create:
        if isSignedIn()
        && request.resource.data.toUserId is string
        && request.resource.data.caseId is string
        && (
          caseRefBy(request.resource.data.caseId).data.createdBy == request.auth.uid ||
          caseRefBy(request.resource.data.caseId).data.assignedTo == request.auth.uid
        );
    }

    // Bloqueia tudo o mais
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
